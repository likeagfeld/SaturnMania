/* --- Per-zone allocation tracking (Phase 2.1 teardown) -----------------
 *
 * Every per-zone resource loaded via jo_fs_read_file is tracked here so
 * zone_teardown can jo_free it before the next zone loads. Without this
 * each Act 1 -> Act 2 transition would leak ~400 KB into the 576 KB pool
 * and the third transition would exhaust it.
 *
 * One exception: ZA_FG_CEL is tracked but NOT freed by zone_teardown.
 * The original comment in setup_ghz_foreground notes that
 * jo_vdp2_set_nbg1_8bits_image may retain internal pointers into the
 * cell buffer, and freeing it from underneath jo corrupts NBG1 state on
 * subsequent loads. We accept a ~90 KB leak per transition for that one
 * buffer; the other ~310 KB per zone is properly freed.
 *
 * Helper zone_alloc_track() handles the free-old-before-store-new pattern
 * so every setup/load site is a one-liner.
 */
enum {
    ZA_FG_PAL = 0,
    ZA_FG_CEL,      /* leaked intentionally; see comment */
    ZA_FG_PAT,
    ZA_FG_TMAP,
    ZA_SKY_PAL,
    ZA_SKY_DAT,
    ZA_WORLD,
    ZA_RINGS,
    ZA_BUGS,
    ZA_SPRINGS,
    ZA_MONITORS,
    ZA_SIGNS,
    ZA_COUNT
};

static void *g_zone_alloc[ZA_COUNT];

/* Track a freshly-loaded buffer; free the previous occupant of that slot
 * unless it's the cel buffer (ZA_FG_CEL). Returns ptr for chaining. */
static void *zone_alloc_track(int slot, void *ptr)
{
    if (slot != ZA_FG_CEL && g_zone_alloc[slot] != NULL) {
        jo_free(g_zone_alloc[slot]);
    }
    g_zone_alloc[slot] = ptr;
    return ptr;
}

/* Compose a filename = "<g_zones[g_current_zone].prefix><suffix>". Returns
 * pointer to a static 24-byte buffer; valid until the next call. Suffix is
 * the zone-agnostic part: "FG.CEL", "SKY.DAT", "SURF.BIN", etc. */
static char *zone_path(const char *suffix)
{
    static char buf[24];
    const char *p = g_zones[g_current_zone].prefix;
    int i = 0;
    while (*p && i < (int)sizeof(buf) - 1) buf[i++] = *p++;
    while (*suffix && i < (int)sizeof(buf) - 1) buf[i++] = *suffix++;
    buf[i] = 0;
    return buf;
}

