/* Phase 2: per-zone resource descriptor. The runtime composes every level-
 * specific filename from <prefix>+<suffix> at load time, so swapping zones
 * is a `g_current_zone` change followed by a teardown+reload. The bible's
 * Phase 7-9 zone roll-out grows this table; today it has GHZ1 and GHZ2. */
typedef struct {
    const char    *prefix;       /* e.g. "GHZ1", "GHZ2", "CPZ1" */
    unsigned char  music_track;  /* CD-DA track to play on entry */
    unsigned char  next_zone;    /* index reached on signpost touch */
    unsigned short reserved;     /* future flags: WATER/UNDERGROUND/NIGHT */
} zone_desc_t;

static const zone_desc_t g_zones[] = {
    /* idx 0: GHZ Act 1 advances to Act 2 */
