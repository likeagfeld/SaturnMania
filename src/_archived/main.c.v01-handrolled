            g_digit_spr[i] = jo_sprite_add(&img);
        }
    }
    jo_free(spr);
}

/* ---- Title overlay sprites (Phase 3.1: real Mania title animation) ----
 *
 * The NBG2 backdrop shows the title island art. On top we render VDP1
 * sprites loaded from the title's Logo.bin:
 *   MLOGO.SPR   = "Game Title" anim (the SONIC MANIA logo, 2 frames)
 *   MPRESS.SPR  = "Press Button" anim (PRESS START prompt, 10 frames)
 *
 * Title-state animation:
 *   ticks 0..59:    logo slides down from off-screen-top to its rest Y
 *   ticks 60..89:   logo settled, no press prompt yet
 *   ticks 90+:      press-button prompt animated at the bottom of screen
 */
#define MLOGO_FRAMES   2
#define MPRESS_FRAMES  10
static int g_sprite_mlogo[MLOGO_FRAMES];
static int g_sprite_mpress[MPRESS_FRAMES];

/* Additional logo parts extracted from Logo.bin: wings backing the logo,
 * the ribbon strip behind the title text, and the ring seal at the
 * bottom of the composite. Layered back-to-front to recreate the full
 * Mania title composition. */
static int g_sprite_mwings;
static int g_sprite_msonic;
static int g_sprite_mribside;
static int g_sprite_mribbon;
static int g_sprite_mring;

static void load_title_sprites(void)
{
    int len, i, w, h, fc;
    unsigned short *spr;
    jo_img img;

    spr = (unsigned short *)jo_fs_read_file("MLOGO.SPR", &len);
    if (spr != NULL) {
        fc = spr[0]; w = spr[1]; h = spr[2];
        if (fc > MLOGO_FRAMES) fc = MLOGO_FRAMES;
        for (i = 0; i < fc; ++i) {
            img.data   = (jo_color *)(spr + 3) + i * w * h;
            img.width  = w;
            img.height = h;
            g_sprite_mlogo[i] = jo_sprite_add(&img);
        }
        jo_free(spr);
    }

    spr = (unsigned short *)jo_fs_read_file("MPRESS.SPR", &len);
    if (spr != NULL) {
        fc = spr[0]; w = spr[1]; h = spr[2];
        if (fc > MPRESS_FRAMES) fc = MPRESS_FRAMES;
        for (i = 0; i < fc; ++i) {
            img.data   = (jo_color *)(spr + 3) + i * w * h;
            img.width  = w;
            img.height = h;
            g_sprite_mpress[i] = jo_sprite_add(&img);
        }
        jo_free(spr);
    }

    /* Logo wings (144x144 backing). */
    spr = (unsigned short *)jo_fs_read_file("MWINGS.SPR", &len);
    if (spr != NULL) {
        w = spr[1]; h = spr[2];
        img.data = (jo_color *)(spr + 3);
        img.width = w; img.height = h;
        g_sprite_mwings = jo_sprite_add(&img);
        jo_free(spr);
    }
    /* Ribbon center (176x56 strip behind the title text). */
    spr = (unsigned short *)jo_fs_read_file("MRIBBON.SPR", &len);
    if (spr != NULL) {
        w = spr[1]; h = spr[2];
        img.data = (jo_color *)(spr + 3);
        img.width = w; img.height = h;
        g_sprite_mribbon = jo_sprite_add(&img);
        jo_free(spr);
    }
    /* Ring seal at the bottom of the composite logo. */
    spr = (unsigned short *)jo_fs_read_file("MRING.SPR", &len);
    if (spr != NULL) {
        w = spr[1]; h = spr[2];
        img.data = (jo_color *)(spr + 3);
        img.width = w; img.height = h;
        g_sprite_mring = jo_sprite_add(&img);
        jo_free(spr);
    }
    /* TitleSonic — full 49-frame entrance animation streamed from
     * cd/TSONIC.ATL (4-bpp Color-Bank-16 atlas in VDP1 VRAM).  This
     * replaces the prior static MSONIC.SPR fallback.  See
     * docs/titlesonic_implementation.md and docs/large_sprite_anim_strategy.md
     * for the rationale.  Soft-fails if the atlas is missing — title
     * still renders, Sonic just doesn't appear. */
    if (!title_sonic_load()) {
        /* Fallback for missing/bad atlas: load the legacy static MSONIC.SPR
         * pose so we never ship a totally empty title state. */
        spr = (unsigned short *)jo_fs_read_file("MSONIC.SPR", &len);
        if (spr != NULL) {
            w = spr[1]; h = spr[2];
            img.data = (jo_color *)(spr + 3);
            img.width = w; img.height = h;
            g_sprite_msonic = jo_sprite_add(&img);
            jo_free(spr);
        }
    } else {
        /* Atlas loaded — disable the legacy single-frame draw. */
        g_sprite_msonic = -1;
    }
    /* Ribbon side banner — Ribbon Wave anim 2 frame 0 (56x72). Per decomp
     * TitleLogo.c the RIBBON entity draws this twice (FLIP_X + NONE) to
     * form both halves of the side banner around the orb. Wave loops
     * once per frame; we ship the static settled pose for now. */
    spr = (unsigned short *)jo_fs_read_file("MRIBSIDE.SPR", &len);
    if (spr != NULL) {
        w = spr[1]; h = spr[2];
        img.data = (jo_color *)(spr + 3);
        img.width = w; img.height = h;
        g_sprite_mribside = jo_sprite_add(&img);
        jo_free(spr);
    }
}

/* Draw a single 8x8 glyph at screen top-left position (sx, sy). */
static void hud_glyph(int glyph, int sx, int sy)
{
    jo_sprite_draw3D(g_digit_spr[glyph],
                     (sx + DIGIT_W / 2) - 160,
                     (sy + DIGIT_H / 2) - 112,
                     HUD_Z);
}

/* Draw a non-negative integer right-justified into `width` glyph cells at
 * (sx, sy). Leading positions are left BLANK (not zero-padded). Returns the
 * pixel-X just past the last drawn glyph (always at sx + width*DIGIT_W). */
static int hud_number(int value, int width, int sx, int sy, bool zero_pad)
{
    int  i;
    int  digits[8];
    bool seen = false;
    for (i = 0; i < width; ++i) {
        digits[i] = value % 10;
        value /= 10;
    }
    for (i = width - 1; i >= 0; --i) {
        int  d = digits[i];
        bool draw = zero_pad || d != 0 || seen || i == 0;
        if (draw) {
            hud_glyph(d, sx + (width - 1 - i) * DIGIT_W, sy);
            seen = true;
        }
    }
    return sx + width * DIGIT_W;
}

/* Top-left HUD:
 *   line 0:  [RING-icon] [3-digit count]              -- collected rings
 *   line 1:  [6-digit score, zero-padded]              -- total score
 *   line 2:  [m] [:] [ss] [:] [cc]                     -- Mania timer m:ss:cc
 */
static void draw_hud(void)
{
    int sy, mins, secs, cs, sx;

    /* Line 0 -- ring icon then the count, no leading zeros. */
    sy = HUD_Y;
    hud_glyph(GLYPH_RING, HUD_X, sy);
    hud_number(g_rings_collected, 3, HUD_X + DIGIT_W + 2, sy, false);

    /* Line 1 -- 6-digit score, zero-padded for the classic look. */
    sy += HUD_LINE_H;
    hud_number(g_score, 6, HUD_X, sy, true);

    /* Line 2 -- m:ss:cc Mania timer. 60 game-ticks = 1 second; cc is the
     * count of hundredths within the current second. */
    sy += HUD_LINE_H;
    secs  = g_game_ticks / 60;
    cs    = (g_game_ticks % 60) * 100 / 60;
    mins  = secs / 60;
    secs %= 60;
    sx = HUD_X;
    sx = hud_number(mins, 1, sx, sy, true);
    hud_glyph(GLYPH_COLON, sx, sy); sx += DIGIT_W;
    sx = hud_number(secs, 2, sx, sy, true);
    hud_glyph(GLYPH_COLON, sx, sy); sx += DIGIT_W;
    sx = hud_number(cs,   2, sx, sy, true);
}

/* ---- Sonic sprites ----------------------------------------------------
 * jo_sprite_add copies pixel data into VDP1 VRAM via jo_dma_copy (see
 * jo_engine/sprites.c:220), so the Work-RAM source buffer is free to
 * release after the add finishes. Same pattern for every SPR atlas we
 * load -- frees recover ~55KB of pool across all sprite atlases. */
static void load_sonic_sprites(void)
{
    jo_img img;
    int len, i, ww, hh;
    unsigned short *idle, *walk;

    idle = (unsigned short *)jo_fs_read_file("SONIC.SPR", &len);
    img.data   = (jo_color *)idle;
    img.width  = SPR_W;
    img.height = SPR_H;
    g_sonic_idle = jo_sprite_add(&img);
    jo_free(idle);

    walk = (unsigned short *)jo_fs_read_file("SONWALK.SPR", &len);
    g_walk_count = walk[0];
    ww = walk[1];
    hh = walk[2];
    if (g_walk_count > MAX_WALK) g_walk_count = MAX_WALK;
    for (i = 0; i < g_walk_count; ++i) {
        img.data   = (jo_color *)(walk + 3) + i * ww * hh;
        img.width  = ww;
        img.height = hh;
        g_sonic_walk[i] = jo_sprite_add(&img);
    }
    jo_free(walk);
}

static void draw_sonic(int sx, int sy, bool moving, bool facing_left)
{
    int id = (moving && g_walk_count) ? g_sonic_walk[g_anim % g_walk_count]
                                      : g_sonic_idle;
    if (facing_left) jo_sprite_enable_horizontal_flip();
    jo_sprite_draw3D(id, sx, sy, SPRITE_Z);
    if (facing_left) jo_sprite_disable_horizontal_flip();
}

/* ---- Collision world (per-column surface from TileConfig.bin) -------- */
static void setup_collision_world(void)
{
    int len;
    g_world.raw       = (const unsigned char *)zone_alloc_track(ZA_WORLD,
            jo_fs_read_file(zone_path("SURF.BIN"), &len));
    /* GHZSURF.BIN is 4 bytes per column; width = file size / 4. */
    g_world.width_px  = len >> 2;
    g_world.height_px = g_fg_ys << 4;  /* tile rows * 16 px */
}

/* ---- Game states ------------------------------------------------------ */
static void enter_titlecard(void)
{
    g_state      = STATE_TITLECARD;
    g_tcard_tick = 0;
}

/* Draw the title-card overlay: ring-icon + digit "1" slide in from the
 * right, hold at screen-centre, slide out to the left. The title backdrop
 * (palms / sun / sky / Sonic at title pose) keeps drawing underneath via
 * draw_title() called from the case branch -- the card is just the moving
 * glyph pair on top. Linear easing for now; ease-out cubic is a follow-up. */
static void draw_titlecard(void)
{
    int  t = g_tcard_tick;
    int  card_x;
    int  card_y = 90;                                /* screen Y of the card  */
    int  offscreen_x = SCR_W + 32;                   /* fully off the right   */
    int  centre_x    = SCR_W / 2;
    int  offleft_x   = -32;

    if (t < TCARD_IN_END) {
        /* Slide in: t 0..23 -> offscreen_x -> centre_x */
        card_x = offscreen_x +
                 ((centre_x - offscreen_x) * t) / TCARD_IN_END;
    } else if (t < TCARD_HOLD_END) {
        card_x = centre_x;
    } else if (t < TCARD_END) {
        /* Slide out: t 90..113 -> centre_x -> offleft_x */
        int phase = t - TCARD_HOLD_END;
        int span  = TCARD_END - TCARD_HOLD_END;
        card_x = centre_x +
                 ((offleft_x - centre_x) * phase) / span;
    } else {
        return;                                       /* done; switch fires the transition */
    }

    /* Two 8x8 glyphs side by side: ring-icon as a stylised "act" marker on
     * the left, the "1" digit on the right. jo_sprite_draw3D is centre-origin
     * (0,0 = screen centre), so subtract 160/112 to convert from top-left
     * screen coords. */
    {
        int icon_cx = card_x - DIGIT_W;              /* centre of icon glyph  */
        int dig_cx  = card_x + DIGIT_W;              /* centre of digit glyph */
        int cy      = card_y + DIGIT_H / 2;
        jo_sprite_draw3D(g_digit_spr[GLYPH_RING], icon_cx - 160, cy - 112, HUD_Z);
        jo_sprite_draw3D(g_digit_spr[1],           dig_cx  - 160, cy - 112, HUD_Z);
    }
}

/* Forward declarations for zone_advance below (defined later in the file). */
static void setup_ghz_foreground(void);
static void setup_ghz_sky(void);
static void setup_collision_world(void);
static void load_rings(void);
static void load_badniks(void);
static void load_objects(void);
static void enter_game(void);

/* Phase 2: transition from current zone to g_zones[].next_zone.
 *
 * Called from the signpost-touch handler. Preserves the cumulative score
 * across the transition (Mania-style scoring). For Phase 2 MVP this does
 * an instant snap (no fade) and re-calls every per-zone setup function;
 * the existing jo_fs_read_file allocations leak ~90 KB per transition
 * (the FG cell bank that the engine intentionally retains -- see
 * setup_ghz_foreground). Pool headroom of ~80 KB tolerates ONE transition;
 * Phase 2.1 follow-up adds proper pointer-tracked teardown so the table
 * can grow to all 24 acts.
 *
 * Note on jo internal state: calling jo_vdp2_set_nbg1_8bits_image,
 * jo_create_palette_from, and jo_vdp2_set_nbg2_8bits_image a second time
 * is not formally documented as safe; the failure mode if any would be a
 * VDP2 render glitch on Act 2. Verified empirically.
 */
static void zone_advance(void)
{
    int saved_score = g_score;

#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
    /* Stop the current zone's BGM before swapping tracks. */
    jo_audio_stop_cd();
#endif

    /* Swap to the next zone descriptor; all zone_path() compositions
     * downstream will resolve against the new prefix from here on. */
    g_current_zone = g_zones[g_current_zone].next_zone;

    /* Reload every per-zone asset with the new prefix. Each setup_/load_
     * function uses zone_path() so the filename derives from
     * g_zones[g_current_zone].prefix automatically.
     * setup_ghz_sky() is called by enter_game() below, so it isn't
     * called here -- otherwise the sky bitmap loads twice per transition. */
    setup_ghz_foreground();
    setup_collision_world();
    load_rings();
    load_badniks();
    load_objects();

    /* Reset player + state machine via enter_game (which zeros g_score
     * for a fresh act + restores NBG layer priorities + loads the new
     * zone's sky), then restore the cumulative score. enter_game also
     * kicks off the new zone's CD-DA track. */
    enter_game();
    g_score = saved_score;
}

static void enter_game(void)
{
    int i;
    /* Restore VDP2 layer config after a title-state stint: NBG2 holds the
     * title backdrop with priority 7 + NBG1 hidden (priority 0). Swap NBG2
     * to the per-zone GHZ sky and restore the gameplay plane priorities.
     *
     * Known issue (task #50): the NBG2 bitmap swap appears unreliable on
     * Saturn — captures past title-card transition show title content
     * persisting in NBG2 even after this call. Diagnostic: slScrAutoDisp
     * NBG2-off experiment showed title sprites still drawn from VDP1
     * even with NBG2 forcibly disabled — suggests draw_title() or some
     * persistent VDP1 sprite list is still active. Investigation
     * deferred until Phase A2 (Object/Entity slot manager) lands so we
     * have a clean entity-driven render path. */
    setup_ghz_sky();
    slPriorityNbg1(6);
    slPriorityNbg2(1);

    /* Place Sonic standing on the actual ground at level start (column 0)
     * rather than the previous hard-coded Y=176. */
    int start_y = player_surface_y(&g_world, 0);
    player_init(&g_player, CHAR_SONIC, SMS_FIXED(0.0), JO_MULT_BY_65536(start_y));
    g_player.grounded = true;
    g_autorun = true;
    g_state = STATE_GAME;

    /* Fresh act: zero the act-scoped HUD counters and re-arm every ring. */
    g_score           = 0;
    g_rings_collected = 0;
    g_game_ticks      = 0;
    for (i = 0; i < g_ring_count; ++i) g_ring_active[i] = 1;

    /* Input takeover: autorun stays on until the player presses something.
     * The 30-tick (0.5s) grace ignores any keys held at the moment we enter
     * the game state so emulator focus-grabs / boot transients don't
     * instantly disable autorun. After the grace expires, the first rising
     * edge on LEFT/RIGHT/A/B/C flips autorun off for the rest of the act. */
    g_input_grace = 30;
    g_prev_left = g_prev_right = g_prev_jump = false;

    /* Per-zone CD-DA track from g_zones[].music_track. tools/build_cdda.py
     * lays the data on track 1 and audio on track 2; future per-zone tracks
     * extend that to track 3, 4, ... See bible Phase 2.1 follow-up for the
     * multi-track CD-DA build pipeline. */
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
    {
        unsigned char tn = g_zones[g_current_zone].music_track;
        jo_audio_play_cd_track(tn, tn, true);
    }
#endif
    /* Note: agent-suggested `slSynch(); slSynch();` here was removed
     * after verification — calling slSynch from INSIDE a jo callback
     * (this enter_game runs nested inside game_tick which runs from
     * jo_core_run's slSynch loop at jo-engine/jo_engine/core.c:585-637)
     * desynchronizes VDP1's dual command table and produces a one-frame
     * garbled VRAM display. The VDP1 sprite lag (faq-reference.md:257)
     * is a real issue but the correct fix is at jo_main's outer scope,
     * not nested. Tracking as a per-frame "transition cooldown" counter
     * follow-up. */
}

#define CAM_FOOT_OFFSET   28   /* Sonic's feet sit ~28 px below screen centre */

static void draw_game(void)
{
    int max_cam_x = (g_fg_xs << 4) - SCR_W;
    int max_cam_y = g_world.height_px - SCR_H;
    int px        = JO_FIXED_TO_INT(g_player.xpos);
    int py        = JO_FIXED_TO_INT(g_player.ypos);

    g_cam_x = px - SONIC_SCR_X;
    if (g_cam_x < 0)          g_cam_x = 0;
    if (g_cam_x > max_cam_x)  g_cam_x = max_cam_x;

    /* Vertical camera: keep Sonic's feet at (SCR_H/2 + CAM_FOOT_OFFSET) on
     * screen so a chunk of ground is visible below him -- classic Sonic. */
    g_cam_y = py - (SCR_H / 2) - CAM_FOOT_OFFSET;
    if (g_cam_y < 0)          g_cam_y = 0;
    if (g_cam_y > max_cam_y)  g_cam_y = max_cam_y;

    fg_build_page();
    slScrPosNbg2(JO_MULT_BY_65536(g_cam_x >> 2),
                 JO_MULT_BY_65536(g_cam_y >> 2));     /* sky parallax 1/4 in both axes */

    /* Rings: world-coord cull + AABB hit-test + animated sprite per active. */
    draw_rings(g_cam_x, g_cam_y, px, py);

    /* Static objects: springs / item monitors / end-of-act signpost. */
    draw_springs (g_cam_x, g_cam_y, px, py);
    draw_monitors(g_cam_x, g_cam_y, px, py);
    draw_signpost(g_cam_x, g_cam_y, px, py);

    /* Badniks: patrol + ground-follow + stomp/hurt vs Sonic. */
    draw_badniks(g_cam_x, g_cam_y, px, py);

    /* HUD: ring-icon + count, score, timer at top-left, on top of gameplay. */
    draw_hud();

    {
        /* jo_sprite_draw3D is CENTRE-origin (0,0 = screen centre); convert the
         * top-left screen position (sx,sy) via sx-160, sy-112. */
        bool moving = g_player.grounded && JO_ABS(g_player.gsp) > SMS_FIXED(0.4);
        int  sx     = (px - g_cam_x) - 160;
        int  sy     = (py - g_cam_y) - 112 - (SPR_H / 2);  /* sprite anchor is centre */
        draw_sonic(sx, sy, moving, g_player.facing_left);
    }
}

/* ---- Title-state draw (per docs/title_ground_truth.md) -----------------
 *
 * AUTHORITATIVE source: github.com/RSDKModding/Sonic-Mania-Decompilation
 * (TitleSetup.c TitleLogo.c) + Scene1.bin entity coordinates parsed by
 * tools/parse_title_entities.py.
 *
 * Entity world coordinates from Scene1.bin (cam X = 256-160 = 96; jo
 * center-anchored coords = world - (256, 112)):
 *
 *   EMBLEM       world (256, 108)  jo ( 0,  -4)  Wings -- FLIP_NONE + FLIP_X
 *   RIBBON       world (256, 144)  jo ( 0,  32)  Ribbon -- FLIP_X + FLIP_NONE
 *                                                 + showRibbonCenter post-flash
 *   GAMETITLE    world (256, 182)  jo ( 0,  70)  MANIA wordmark (frame 0)
 *   POWERLED     destroyed @ frame 31 -- never on final title
 *   RINGBOTTOM   world (256, 148)  jo ( 0,  36)
 *   COPYRIGHT    world (432, 224)  jo (172, 112) off-screen on 320-wide
 *   PRESSSTART   world (256, 212)  jo ( 0, 100)  blink: !(timer & 0x10)
 *
 * State timeline (compressed for early ship; full timing reinstated when
 * the intro electricity-ring asset + Sonic-on-title are wired in):
 *   t=  0 .. 64   : Wait phase -- nothing drawn yet
 *   t= 64 .. 96   : AnimateUntilFlash -- EMBLEM + RIBBON appear
 *   t= 96 ..112   : FlashIn -- white 0xF0F0F0 flash; at end the rest
 *                   become visible + ribbon center swap-in
 *   t=112 ..172   : WaitForSonic (compressed; Sonic anim not yet wired)
 *   t=172 ..292   : SetupLogo -- PRESS START timer counts to 120
 *   t>=292        : WaitForEnter -- PRESS START blinks
 */
#define TITLE_WAIT_END     64
#define TITLE_UNFURL_END   96
#define TITLE_FLASH_END    112
#define TITLE_SONIC_END    172
#define TITLE_PRESS_START  292

/* Per-sprite jo-center offsets compensating for asymmetric pivots in the
 * extracted SPR canvases. convert_anim_sprite.py composes a canvas with
 * the pivot point at (-left, -top) of the bounding box; jo's draw3D
 * centre-anchors the canvas. So we offset the draw position so the
 * canvas pivot lands at the desired entity world coordinate.
 *
 * EMBLEM (Logo Wings anim 0, pivot=(-144,-72), w=h=144): pivot at canvas
 *   right-edge -> shift draw left by 72 (for FLIP_NONE) / right by 72
 *   (for FLIP_X) so both halves' pivot lands at the same world point.
 * RIBBON (Ribbon Center anim 3, pivot=(-79,-24), 176x52): canvas is
 *   slightly off-centre (pivot at canvas (79, 24); canvas centre at
 *   (88, 26)). Single draw lands the pivot ~9px right of the jo coord.
 *   For exact alignment shift draw by (-9, -2) for FLIP_NONE / (+9, -2)
 *   for FLIP_X. (Same Ribbon-Center sprite is used until Ribbon-Unfurl
 *   anim 1 is extracted separately.)
 * GAMETITLE (Game Title anim 4 f0, pivot=(-69,-23), 137x46): nearly
 *   centered pivot; no offset.
 * RINGBOTTOM (Ring Bottom anim 7, pivot=(-60, 0), 120x25): pivot at
 *   canvas top-edge -> shift draw down by canvas_h/2 = 12 for visible
 *   pivot alignment with the entity Y. */
static void draw_title(void)
{
    int press_frame;

    /* AnimateUntilFlash: EMBLEM (Wings) + RIBBON (Unfurl) appear. */
    if (g_ticks >= TITLE_WAIT_END) {
        /* EMBLEM at jo (0, -4) -- FLIP_NONE then FLIP_X */
        jo_sprite_draw3D(g_sprite_mwings, -72, -4, SPRITE_Z + 30);
        jo_sprite_enable_horizontal_flip();
        jo_sprite_draw3D(g_sprite_mwings, +72, -4, SPRITE_Z + 31);
        jo_sprite_disable_horizontal_flip();

        /* RIBBON side banners — Ribbon Wave anim 2 frame 0 (MRIBSIDE.SPR,
         * 56x72, pivot (-121,-13)). Per decomp TitleLogo.c Draw():
         * FLIP_X first, then FLIP_NONE, at the same entity position
         * (256, 144) world. The asymmetric pivot makes one draw extend
         * leftward and the mirror extend rightward, forming both halves
         * of the side banner around the central orb.
         *
         * Saturn jo coord conversion: entity (256, 144) -> jo (0, 32).
         * Sprite canvas is 56x72; the pivot (-121, -13) means the
         * sprite's logical origin is 65px LEFT of canvas centre and
         * 23px ABOVE. To anchor the logical-origin point at jo (0, 32),
         * draw the canvas centre offset by (+65, +23) for FLIP_NONE
         * (banner extends LEFT of center) and (-65, +23) for FLIP_X
         * (banner extends RIGHT of center, mirrored). */
        jo_sprite_enable_horizontal_flip();
        jo_sprite_draw3D(g_sprite_mribside, -65, 32 + 23, SPRITE_Z + 22);
        jo_sprite_disable_horizontal_flip();
        jo_sprite_draw3D(g_sprite_mribside, +65, 32 + 23, SPRITE_Z + 22);
    }

    /* FlashIn end -> all remaining logos visible. Ribbon-Center (anim 3,
     * separate animator) appears here -- but we're already drawing
     * MRIBBON which IS Ribbon-Center, so no extra draw needed until we
     * separately extract Ribbon-Unfurl/Wave. */
    if (g_ticks >= TITLE_FLASH_END) {
        /* Ribbon Center (anim 3, "SONIC" wordmark, MRIBBON.SPR 176x52,
         * pivot=(-79,-24)) is a SEPARATE animator on the RIBBON entity,
         * gated by showRibbonCenter=true (only true post-FlashIn per
         * decomp TitleSetup_State_FlashIn). Drawn ONCE on top of the
         * side banners — NOT mirrored. */
        jo_sprite_draw3D(g_sprite_mribbon, +9, 30, SPRITE_Z + 19);
        /* GAMETITLE = "MANIA" wordmark at jo (0, 70). Frame 0 only --
         * frame 1 = "DISCOVERY" is Plus-DLC; we ship base Mania. */
        jo_sprite_draw3D(g_sprite_mlogo[0], 0, 70, SPRITE_Z + 10);
        /* RINGBOTTOM at jo (0, 36) -- pivot at canvas top, shift +12. */
        jo_sprite_draw3D(g_sprite_mring, 0, 48, SPRITE_Z);
        /* TitleSonic — 49-frame palettized entrance animation streamed
         * at boot from cd/TSONIC.ATL.  title_sonic_draw() walks a
         * cumulative-duration table to pick the right frame and applies
         * each frame's individual pivot.  After the entrance arc
         * completes (RSDK loop=48), it holds on frame 48 (settled pose).
         * Falls back to the legacy static draw if the atlas didn't load. */
        if (g_sprite_msonic < 0) {
            /* g_ticks is the title-state tick counter (resets to 0 at
             * title entry); title_sonic_current_frame walks the
             * cumulative-duration table from there.  The TitleSonic
             * entity world position is (252, 104); per-frame pivots
             * applied inside title_sonic_draw. */
            title_sonic_draw(g_ticks, SPRITE_Z + 5);
        } else {
            jo_sprite_draw3D(g_sprite_msonic, +1, -39, SPRITE_Z + 5);
        }
    }

    /* PRESS START at jo (0, 100). Decomp blink: drawn only when
     * !(timer & 0x10) -- 16 frames on, 16 frames off, 32-frame period.
     * Timer starts when SetupLogo completes (TITLE_PRESS_START). */
    if (g_ticks >= TITLE_PRESS_START) {
        int blink_t = g_ticks - TITLE_PRESS_START;
        if (!(blink_t & 0x10)) {
            press_frame = (blink_t / 6) % MPRESS_FRAMES;
            jo_sprite_draw3D(g_sprite_mpress[press_frame], 0, 100, SPRITE_Z);
        }
    }
}

/* ---- Phase 3: act-clear, tally, save ---------------------------------- */

/* Mania-style time bonus: faster clears award more. Brackets per
 * decompilation reference values; falls to 0 if you take > 5 minutes. */
static int _calc_time_bonus(int ticks)
{
    int secs = ticks / 60;
    if (secs <  30) return 50000;
    if (secs <  45) return 10000;
    if (secs <  60) return  5000;
    if (secs <  90) return  4000;
    if (secs < 120) return  3000;
    if (secs < 180) return  1000;
    if (secs < 240) return   500;
    if (secs < 300) return   100;
    return 0;
}

#define ACTCLEAR_TICKS  120   /* 2 sec spin + walk-off                    */
#define TALLY_ROLL      120   /* 2 sec digit roll-up                      */
#define TALLY_HOLD_MAX  240   /* 4 sec auto-advance after roll completes  */

static void enter_actclear(void)
{
    g_state            = STATE_ACTCLEAR;
    g_state_tick       = 0;
    g_tally_time_bonus = _calc_time_bonus(g_game_ticks);
    g_tally_ring_bonus = g_rings_collected * 100;
    g_tally_total      = 0;
}

static void enter_tally(void)
{
    g_state      = STATE_TALLY;
    g_state_tick = 0;
}

/* Render the spinning signpost overlay. draw_game() draws the playfield
 * + entities; the signpost-position sprite gets the spin frame instead
 * of frame 0 (which draw_signpost suppresses when g_act_cleared is set). */
static void draw_actclear(void)
{
    int frame;
    draw_game();
    if (g_sign_count == 0) return;
    frame = (g_state_tick < 80) ? (g_state_tick / 10) % SIGN_FRAMES : 0;
    {
        int rx = *(const unsigned short *)(g_sign_buf);
        int ry = *(const unsigned short *)(g_sign_buf + 2);
        int sx = rx - g_cam_x;
        int sy = ry - g_cam_y;
        jo_sprite_draw3D(g_sprite_sign[frame],
                         (sx + 8) - 160, (sy + 12) - 112, SPRITE_Z);
    }
}

/* Tally screen: rolling-digit bonus display. Number-only layout for now
 * (HUD font has digits + ring icon + colon only; word labels like "TIME
 * BONUS" become a Phase 3.1 follow-up once a letter glyph atlas exists).
 * Layout, centred-ish on a 320x240 screen:
 *   row 0  (sy=72):  [ring-icon]  <time bonus, 6-digit>
 *   row 1  (sy=92):  [ring-icon]  <ring bonus, 6-digit>
 *   row 2  (sy=120): <running total, 7-digit, larger spacing>
 */
static void draw_tally(void)
{
    int target = g_tally_time_bonus + g_tally_ring_bonus;
    int roll   = (g_state_tick < TALLY_ROLL)
               ? (target * g_state_tick / TALLY_ROLL)
               : target;
    g_tally_total = roll;
    {
        int cx_left  = 80;
        int cx_value = 144;
        int sy       = 72;
        hud_glyph(GLYPH_RING, cx_left, sy);
        hud_number(g_tally_time_bonus, 6, cx_value, sy, true);
        sy += 20;
        hud_glyph(GLYPH_RING, cx_left, sy);
        hud_number(g_tally_ring_bonus, 6, cx_value, sy, true);
        sy += 28;
        hud_number(roll, 7, cx_value - DIGIT_W, sy, true);
    }
}

static void game_tick(void)
{
    ++g_ticks;
    if ((g_ticks & 3) == 0)
        ++g_anim;

    switch (g_state) {
        case STATE_TITLE:
            draw_title();
#ifdef QA_MODE
            /* QA build only: title holds until START so qa_refdiff has a
             * deterministic static view to diff against the golden. The
             * release binary auto-advances through the title card into
             * the demo (see #else). */
            if (jo_is_pad1_key_pressed(JO_KEY_START))
                enter_titlecard();
#else
            /* Release: 2-second title, then auto-advance into the title
             * card cinematic, which in turn transitions into the demo. */
            if (jo_is_pad1_key_pressed(JO_KEY_START) || g_ticks > 120)
                enter_titlecard();
#endif
            break;

        case STATE_TITLECARD:
            draw_title();                            /* keep the title scene  */
            draw_titlecard();                        /* overlay sliding card  */
            if (++g_tcard_tick >= TCARD_END)
                enter_game();
            break;

        case STATE_GAME:
            ++g_game_ticks;                         /* HUD timer (60 ticks/s) */
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
            bgm_pump();                             /* kick off / re-trigger BGM */
#endif

            /* Input takeover: after the boot-transient grace, the first
             * fresh press (rising edge) on LEFT/RIGHT/A/B/C disables autorun
             * for the rest of the act. player.c already reads those keys
             * directly for steering + jump; autorun=false just stops the
             * forced-right-input that was driving the demo. */
            if (g_input_grace) {
                --g_input_grace;
            } else if (g_autorun) {
                bool now_l = jo_is_pad1_key_pressed(JO_KEY_LEFT);
                bool now_r = jo_is_pad1_key_pressed(JO_KEY_RIGHT);
                bool now_j = jo_is_pad1_key_pressed(JO_KEY_A) ||
                             jo_is_pad1_key_pressed(JO_KEY_B) ||
                             jo_is_pad1_key_pressed(JO_KEY_C);
                if ((now_l && !g_prev_left) ||
                    (now_r && !g_prev_right) ||
                    (now_j && !g_prev_jump)) {
                    g_autorun = false;
                }
                g_prev_left  = now_l;
                g_prev_right = now_r;
                g_prev_jump  = now_j;
            }

            /* Auto-jump AI: fires while autorun is still on (demo mode).
             * Two trigger conditions:
             *   1. Moving (|gsp| > 1) and the surface 24 px ahead steps up
             *      or down by more than the stair tolerance -- early hop
             *      lets Sonic clear small walls before he touches them.
             *   2. Blocked (gsp == 0 after the wall-block in player.c set
             *      both gsp/xsp to 0) and a surface within 24 px ahead is
             *      shallower than the current ypos -- the mound the demo
             *      ran into is jumpable. Without this, Sonic plants
             *      against the first invisible-walling mound and the demo
             *      stops there forever (Gate 8's "invisible-wall stall"). */
            if (g_autorun && g_player.grounded) {
                int look_x = JO_FIXED_TO_INT(g_player.xpos) + 24;
                int look_y = player_surface_y(&g_world, look_x);
                int cur_y  = JO_FIXED_TO_INT(g_player.ypos);
                bool moving  = JO_ABS(g_player.gsp) > SMS_FIXED(1.0);
                bool blocked = g_player.gsp == 0 && g_player.xsp == 0;
                bool step_change = (look_y != SMS_NO_FLOOR &&
                                    (look_y < cur_y - 17 || look_y > cur_y + 17));
                bool wall_ahead  = (look_y != SMS_NO_FLOOR && look_y < cur_y - 8);
                if ((moving && step_change) || (blocked && wall_ahead)) {
                    g_player.ysp      = -g_player.jump_force;
                    g_player.grounded = false;
                    g_player.jumping  = true;
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                    if (g_audio_ready) jo_audio_play_sound(&g_sfx_jump);
#endif
                }
            }

            player_update(&g_player, &g_world, g_autorun);

            /* Phase 4: post-update hurt/death checks.
             *  - decrement invuln flash timer
             *  - death pit if player fell below the level
             *  - on death: decrement lives, respawn at level-start (or
             *    enter STATE_GAMEOVER if no lives left)
             */
            if (g_hurt_timer > 0) --g_hurt_timer;
            if (!g_dead) {
                int py = JO_FIXED_TO_INT(g_player.ypos);
                if (py > g_world.height_px + 64) g_dead = true;
            }
            if (g_dead) {
                --g_lives;
                if (g_lives <= 0) {
                    g_state      = STATE_GAMEOVER;
                    g_state_tick = 0;
                } else {
                    /* Respawn at level start. Phase 4.1: respawn at the
                     * last touched BoundsMarker checkpoint instead. */
                    int spawn_y = player_surface_y(&g_world, 0);
                    player_init(&g_player, CHAR_SONIC, SMS_FIXED(0.0),
                                JO_MULT_BY_65536(spawn_y));
                    g_player.grounded = true;
                    g_hurt_timer      = 0;
                    g_dead            = false;
                    /* Keep score + ring count + timer; just respawn the body. */
                }
            }
            draw_game();
            break;

        case STATE_ACTCLEAR:
            ++g_state_tick;
            /* Auto-walk Sonic off-screen-right for the first 60 ticks of the
             * cinematic, then freeze him. xsp is set directly so the player
             * physics state machine still ground-follows naturally. */
            if (g_state_tick < 60) {
                g_player.xsp = SMS_FIXED(2.5);
                player_update(&g_player, &g_world, false);
            }
            draw_actclear();
            if (g_state_tick >= ACTCLEAR_TICKS) {
                enter_tally();
            }
            break;

        case STATE_TALLY:
            ++g_state_tick;
            draw_tally();
            /* After the digit roll completes, accept START to advance, or
             * auto-advance after TALLY_HOLD_MAX additional ticks. */
            if (g_state_tick >= TALLY_ROLL) {
                bool start = jo_is_pad1_key_pressed(JO_KEY_START);
                bool timeout = g_state_tick >= TALLY_ROLL + TALLY_HOLD_MAX;
                if (start || timeout) {
                    sms_save_t save;
                    g_score += g_tally_total;  /* award accumulated bonus */
                    /* Persist the post-tally state to backup RAM. The slot
                     * stores the NEXT zone to enter so a fresh boot resumes
                     * at the start of the next act, not at the just-cleared
                     * act. lives/emeralds/char_select are Phase 4/11/12
                     * additions and stay 0 for now. */
                    save.magic        = SMS_SAVE_MAGIC;
                    save.version      = SMS_SAVE_VERSION;
                    save.current_zone = g_zones[g_current_zone].next_zone;
                    save.score        = g_score;
                    save.best_score   = g_score;   /* PLACE_HOLDER: max-of with existing best is Phase 5 */
                    save.lives        = 3;
                    save.emeralds     = 0;
                    save.char_select  = 0;
                    save.pad          = 0;
                    sms_save_write(&save);
                    zone_advance();
                }
            }
            break;

        case STATE_GAMEOVER:
            /* Lives exhausted. Show "GAME OVER" overlay for 240 ticks
             * (4 sec), then return to title with lives reset. Keep
             * draw_game() running underneath so the playfield freezes
             * visibly during the overlay. */
            ++g_state_tick;
            draw_game();
            /* Center-ish "GAME OVER" via existing HUD font: spell with
             * digit glyphs as a placeholder since no letter glyphs yet.
             * Use 0x06 (=6) as the "G" stand-in, 0x00 (0) for the O's --
             * really this just blocks the screen; proper letter atlas is
             * a Phase 5 menu task. */
            {
                int sy = 100;
                hud_glyph(0, 132, sy);
                hud_glyph(0, 140, sy);
                hud_glyph(0, 148, sy);
                hud_glyph(0, 156, sy);
                hud_glyph(0, 172, sy);
                hud_glyph(0, 180, sy);
                hud_glyph(0, 188, sy);
                hud_glyph(0, 196, sy);
            }
            if (g_state_tick > 240 || jo_is_pad1_key_pressed(JO_KEY_START)) {
                /* Reset lives + transition back to title. The
                 * title-state setup is in jo_main; we have to undo
                 * enter_game's NBG-priority + sky swap to return to
                 * title visuals. */
                g_lives = 3;
                g_hurt_timer = 0;
                g_dead = false;
                g_score = 0;
                setup_title_bg();
                slPriorityNbg1(0);
                slPriorityNbg2(5);   /* NBG2 < sprite priority so logo overlays */
                g_state = STATE_TITLE;
                g_ticks = 0;
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                jo_audio_play_cd_track(3, 3, true);
#endif
            }
            break;
    }
}

void jo_main(void)
{
    /* Back-color tuned to match the title bitmap's sky exactly. The 320-
     * wide Saturn screen has ~36 px on each side where NBG2 doesn't
     * cover, and that uncovered region shows the back-color. Setting it
     * to the title's sky-blue makes those edges invisible (vs the prior
     * (104,144,224) which read as visible "light blue bars" against the
     * (96,128,224) title sky). User reports 2026-05-26: "still has blue
     * bars at both sides... not taking up entire screen". */
    jo_core_init(JO_COLOR_RGB(96, 128, 224));

    /* Hide ALL NBGs immediately so any in-VRAM garbage from the cold-boot
     * VRAM state doesn't render between jo_core_init and the title's
     * first paint. User reported 2026-05-26: "when game boots before
     * title why are there still garbled visual artifacts from the first
     * level that appear". This is the fix. setup_title_bg() then unhides
     * NBG2 with priority 5 when the title art is fully written. */
    slPriorityNbg0(0);
    slPriorityNbg1(0);
    slPriorityNbg2(0);
    slPriorityNbg3(0);

    /* Phase 3.2 bisect stage 2: re-enabled to actually call into the
     * bisect function so the optimizer doesn't dead-strip the LIBCPK
     * references. */
    intro_video_play("INTRO.CPK");

    setup_ghz_foreground();    /* GHZ streaming foreground on VDP2 NBG1 */
    setup_collision_world();   /* per-column surface table (TileConfig.bin) */
    /* Title-state path: NBG2 holds the real Mania title art. enter_game()
     * later swaps NBG2 to the per-zone GHZ sky and restores NBG layer
     * priorities for gameplay. */
    setup_title_bg();          /* real Mania title art on VDP2 NBG2          */
    slPriorityNbg1(0);         /* hide GHZ FG during title state             */
    /* NBG2 at priority 5: above any other background but BELOW the default
     * VDP1 sprite layer (which sits at priority 6 or higher), so the
     * MLOGO/MPRESS overlays render on top of the title backdrop. */
    slPriorityNbg2(5);
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
    /* Title music: CD-DA track 03 (TitleScreen.ogg). Built into the cue
     * by tools/build_cdda.py in multi-track mode when both track02.wav
     * (GHZ) and track03.wav (title) exist. enter_game later switches to
     * track 02 for gameplay. */
    jo_audio_play_cd_track(3, 3, true);
#endif
    load_sonic_sprites();      /* real Sonic (idle + walk) on VDP1 */
    load_rings();              /* GHZ ring entities + spinning sprite frames */
    load_badniks();            /* GHZ Motobug spawn points + placeholder spr */
    load_objects();            /* Springs, Monitors, Signpost                */
    load_hud_digits();         /* 10 digit glyphs for the ring counter HUD   */
    load_title_sprites();      /* Phase 3.1: MLOGO + MPRESS title overlays   */
    setup_audio();             /* SCSP init + ring/jump SFX                  */
    sms_save_init();           /* Phase 3.1: now a no-op; real backup_mount
                                * deferred to first read/write call so the
                                * FG cell-bank corruption that boot-time
                                * mount caused no longer happens. */

    g_state = STATE_TITLE;

    jo_core_add_vblank_callback(fg_vblank);   /* DMA page to VRAM during V-blank */
    jo_core_add_callback(game_tick);
    jo_core_run();
}
