extern void jo_audio_init(void);

static bool _load_sfx(const char *path, jo_sound *out)
{
    out->sample_rate = 22050;
    out->volume      = JO_DEFAULT_AUDIO_VOLUME;
    return jo_audio_load_pcm((char *)path, JoSoundMono8Bit, out);
}
#endif

static void setup_audio(void)
{
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
    jo_audio_init();
    /* SFX: short s8 mono PCMs at 22050 Hz. jo_audio_load_pcm reads from CD.
     * Each load returns false on failure (missing file, SCSP RAM full); we
     * still set g_audio_ready if the core two (ring + jump) load, since the
     * rest are gameplay-optional. */
    bool ok = _load_sfx("RINGSFX.PCM",   &g_sfx_ring)
           && _load_sfx("JUMPSFX.PCM",   &g_sfx_jump);
    /* The five Phase-1 new slots; failures are non-fatal. */
    _load_sfx("BREAKSFX.PCM",  &g_sfx_break);
    _load_sfx("BOUNCESFX.PCM", &g_sfx_bounce);
    _load_sfx("STOMPSFX.PCM",  &g_sfx_stomp);
    _load_sfx("HURTSFX.PCM",   &g_sfx_hurt);
    _load_sfx("LOSESFX.PCM",   &g_sfx_lose);
    if (ok) g_audio_ready = true;
#endif
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
    /* BGM is intentionally DISABLED in this build (pool/RAM budget). Phase
     * 4h will reintroduce it via CD streaming. */
    g_bgm_ready   = false;
    g_bgm_channel = JO_SOUND_MAX_CHANNEL - 1;
    (void)g_bgm;
#endif
}

#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
/* Re-trigger BGM if it has finished its loop. The first run kicks it off;
 * subsequent runs restart after the PCM ends. The re-trigger gap is one
 * tick (audible) -- a seamless loop needs SCSP-level loop bits or double-
 * buffered streaming (Phase 4h follow-up). */
static void bgm_pump(void)
{
    if (!g_bgm_ready) return;
    if (!jo_audio_is_channel_playing(g_bgm_channel))
        jo_audio_play_sound_on_channel(&g_bgm, g_bgm_channel);
}
#endif

