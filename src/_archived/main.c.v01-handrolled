/* =======================================================================
 *  Streaming GHZ foreground (VDP2 NBG1, cell-scroll, DMA-updated page)
 *
 *  Assets (tools/convert_stream.py, big-endian):
 *    GHZFG.CEL  numCells*64B  256-colour row-major 8x8 cells (cell 0 = blank).
 *    GHZFG.PAT  [u16 nPat] then nPat*4 u16 cell indices per tile (TL,TR,BL,BR).
 *    GHZFG.TMP  [u16 xs][u16 ys] then xs*ys u16 tile-pattern ids (0 = blank).
 *    GHZFG.PAL  256 u16 RGB555.
 *
 *  NBG1 is set up (via jo's cell-mode helper) as: PL_SIZE_1x1, COL_TYPE_256,
 *  CHAR_SIZE_1x1, PNB_1WORD|CN_12BIT, cells in VRAM bank A0, page in bank B0.
 *  Pattern name (1-word, 12-bit char): PN = (cellIndex*2) | (palette<<12) + base
 *  (256-colour 8x8 cell = 0x40 bytes = 2 char units; base = cell offset / 0x20).
 * ======================================================================= */
extern unsigned char  *nbg1_cell;            /* jo's NBG1 char base (VRAM A0) */
extern unsigned short *nbg1_map;             /* jo's NBG1 page    (VRAM B0)   */
#define FG_PAGE_CELLS   64                   /* cells per page row/col        */
#define FG_PAGE_LEN     (FG_PAGE_CELLS * FG_PAGE_CELLS)   /* 4096 PNs          */
#define FG_WIN_TILES    32                   /* 32 tiles = 64 cells = one page */
/* Per-zone unique-cell count; set at zone load from `.CEL` file size /
 * 64. GHZ Act 1 has 1406 cells; Act 2 has a different count; subsequent
 * zones each have their own. Keep < 4096 to fit a single VRAM bank. */
static unsigned short  g_fg_num_cells;

static unsigned short  g_page[FG_PAGE_LEN];  /* page built in Work RAM, DMA'd to VRAM */
static unsigned short *g_fg_pat;             /* tile id -> 4 cell indices      */
static unsigned short *g_fg_tmap;            /* [row*xs + col] tile-pattern ids */
static int             g_fg_xs, g_fg_ys;     /* level size in 16px tiles        */
static jo_palette      g_fg_pal;
static unsigned short  g_fg_paloff;          /* palette id << 12               */
static unsigned short  g_fg_mapoff;          /* char base = (cell byte-offset)/32 */

/* Camera: GHZ Act 1's opening grass sits ~world tile-row 45. Title view pins
 * vertically at this Y; in-game camera now follows Sonic's actual ypos via
 * the collision surface (Phase 3). */
#define CAM_Y_PX        720
#define SONIC_SCR_X     60
#define SONIC_SCR_Y     150
static int             g_cam_x, g_cam_y;
static sms_world_t     g_world;        /* per-column surface from GHZSURF.BIN */

/* Build one 16x16 level tile (4 cells) into the Work-RAM page buffer. The page
 * wraps every 32 tiles; tile (L,R) lands at page cell ((L*2)&63,(R*2)&63), which
 * the VDP2 scroll position re-aligns to the world pixel. */
static void fg_put_tile(int L, int R)
{
    unsigned short        pid = 0;
    const unsigned short *q;
    int                   cc, cr, b;

    if ((unsigned)L < (unsigned)g_fg_xs && (unsigned)R < (unsigned)g_fg_ys)
        pid = g_fg_tmap[R * g_fg_xs + L];
    q  = &g_fg_pat[pid << 2];
    cc = (L << 1) & (FG_PAGE_CELLS - 1);
    cr = (R << 1) & (FG_PAGE_CELLS - 1);
    b  = cr * FG_PAGE_CELLS + cc;
    g_page[b]                     = (unsigned short)(((q[0] << 1) | g_fg_paloff) + g_fg_mapoff);
    g_page[b + 1]                 = (unsigned short)(((q[1] << 1) | g_fg_paloff) + g_fg_mapoff);
    g_page[b + FG_PAGE_CELLS]     = (unsigned short)(((q[2] << 1) | g_fg_paloff) + g_fg_mapoff);
    g_page[b + FG_PAGE_CELLS + 1] = (unsigned short)(((q[3] << 1) | g_fg_paloff) + g_fg_mapoff);
}

/* Rebuild the whole page in Work RAM for the camera window (active display ok -
 * Work RAM has no display contention). */
static void fg_build_page(void)
{
    int L, R;
    int tx = g_cam_x >> 4;
    int ty = g_cam_y >> 4;

    for (R = ty; R < ty + FG_WIN_TILES; ++R)
        for (L = tx; L < tx + FG_WIN_TILES; ++L)
            fg_put_tile(L, R);
}

/* Push the Work-RAM page to VRAM during V-blank. We use slDMAXCopy (SCU DMA,
 * separate controller) rather than slDMACopy (CPU DMA) so we don't share a
 * CPU DMA channel with SGL's sound subsystem -- which DOES use CPU DMA for
 * its internal data transfers. SGL 2.0A release notes section 1.2.1) flags
 * this exact pattern: "CPU DMA transfer channel used for a scroll screen
 * data transfer conflicts with this sound data CPU DMA transfer when a
 * V-blank interrupt occurs." SCU DMA sidesteps the conflict entirely.
 *
 * SCU DMA bypasses the SH-2 cache (slDMAXCopy is NOT cache-aware), so we
 * pass the source via the cache-through alias (0x20000000 OR) to skip the
 * cache entirely and avoid reading stale CPU-cached bytes. */
static void fg_vblank(void)
{
    slDMAXCopy((void *)((unsigned int)g_page | 0x20000000),
               (void *)nbg1_map,
               FG_PAGE_LEN * sizeof(unsigned short),
               Sinc_Dinc_Long);
    slScrPosNbg1(JO_MULT_BY_65536(g_cam_x), JO_MULT_BY_65536(g_cam_y));
}

/* Register NBG1 in cell mode (jo helper) and load the resident cell bank. */
static void setup_ghz_foreground(void)
{
    static jo_img_8bits dummy;
    int                 len;
    unsigned char      *cel;
    unsigned short     *fgpal, *tmp;

    fgpal = (unsigned short *)zone_alloc_track(ZA_FG_PAL,
                jo_fs_read_file(zone_path("FG.PAL"), &len));
    jo_create_palette_from(&g_fg_pal, fgpal, 256);
    g_fg_paloff = (unsigned short)(g_fg_pal.id << 12);

    cel       = (unsigned char *)zone_alloc_track(ZA_FG_CEL,
                jo_fs_read_file(zone_path("FG.CEL"), &len));
    /* `.CEL` is `num_cells * 64` bytes of raw row-major 256-colour 8x8 cells;
     * the count is per-zone so we derive it from the loaded size rather than
     * hard-coding it (GHZ Act 1 = 1406, Act 2 differs, every zone differs). */
    g_fg_num_cells = (unsigned short)(len / 64);
    {
        unsigned short *pat_raw = (unsigned short *)zone_alloc_track(ZA_FG_PAT,
                jo_fs_read_file(zone_path("FG.PAT"), &len));
        g_fg_pat = pat_raw + 1;     /* skip [u16 nPat] header */
    }
    tmp       = (unsigned short *)zone_alloc_track(ZA_FG_TMAP,
                jo_fs_read_file(zone_path("FG.TMP"), &len));
    g_fg_xs   = tmp[0];                 /* SH-2 reads the big-endian u16 natively */
    g_fg_ys   = tmp[1];
    g_fg_tmap = tmp + 2;

    /* jo sets up NBG1 cell mode + NBG1ON and allocates cell(A0)/page(B0). The
     * dummy is the cell buffer itself (8 * g_fg_num_cells * 8 = total bytes),
     * so no extra allocation; jo's reordered cells are then replaced with the
     * real bank. */
    dummy.data   = cel;
    dummy.width  = 8;
    dummy.height = g_fg_num_cells * 8;
    jo_vdp2_set_nbg1_8bits_image(&dummy, g_fg_pal.id, false);
    slPriorityNbg1(6);

    /* char base = byte-offset of the cell bank within its 0x20000 VRAM bank / 32. */
    g_fg_mapoff = (unsigned short)(((unsigned int)nbg1_cell & 0x1FFFF) >> 5);

    /* Upload the resident, row-major cell bank to VRAM via DMA. We intentionally
     * KEEP the Work-RAM source allocated -- jo_vdp2_set_nbg1_8bits_image may
     * retain internal pointers into it, and freeing the block here can corrupt
     * jo's state and freeze the game. The pool has room for both. */
    slDMACopy(cel, (void *)nbg1_cell, g_fg_num_cells * 64);
    (void)cel;

    g_cam_x = 0;
    g_cam_y = CAM_Y_PX;
}

/* ---- GHZ parallax sky on NBG2 (behind NBG1) --------------------------- */
#define SKY_W 176
#define SKY_H 512
static jo_palette      g_sky_pal;
static void setup_ghz_sky(void)
{
    static jo_img_8bits img;
    int len;
    unsigned short *spal = (unsigned short *)zone_alloc_track(ZA_SKY_PAL,
            jo_fs_read_file(zone_path("SKY.PAL"), &len));
    jo_create_palette_from(&g_sky_pal, spal, 256);
    img.data   = (unsigned char *)zone_alloc_track(ZA_SKY_DAT,
            jo_fs_read_file(zone_path("SKY.DAT"), &len));
    img.width  = SKY_W;
    img.height = SKY_H;

    slScrPosNbg2(0, 0);

    /* NBG2 cell-mode swap, applied per data-driven research (sega-saturn-
     * developer skill + DTS96 BIPLANE sample). VDP2 cannot retarget the
     * NBG2 plane safely while the layer is enabled (VDP2 manual §3.3,
     * D:\Claude Saturn Skill Documentation\export\docs\sega_saturn_docs\
     * VDP2_Manual.txt lines 1729-1825): if we leave NBG2ON set during
     * the cell+map rewrite, VDP2 displays a partial mix and the new
     * bitmap never visibly lands -- which is exactly what we observed
     * before this fix (title bitmap persisted into STATE_GAME).
     *
     * Critical gotcha learned the hard way 2026-05-26: slScrAutoDisp is
     * REPLACE (not OR/AND), and the screen-flag bitmask must include
     * ONLY layers that are actually initialized. NBG0/NBG3 are never
     * set up in this project; including their ON bits makes VDP2 read
     * uninitialized VRAM and display garbled tiles. Use NBG1ON only
     * during the swap window. */
    slScrAutoDisp(NBG1ON);                 /* drop NBG2ON cleanly */
    jo_vdp2_set_nbg2_8bits_image(&img, g_sky_pal.id, false, false);
    /* Re-issue plane config (BIPLANE sample's canonical sequence at
     * D:\Claude Saturn Skill Documentation\NOV96_DTS\EXAMPLES\SGL\
     * BIPLANE\MAIN.C:191-206) so VDP2 latches the new layout. */
    slPlaneNbg2(PL_SIZE_1x1);
    slCharNbg2(COL_TYPE_256, CHAR_SIZE_1x1);
    slPriorityNbg1(6);
    slPriorityNbg2(1);
    slScrAutoDisp(NBG1ON | NBG2ON);        /* re-enable cleanly */
}

/* ---- Title backdrop (Phase 3.1 / fix-for-user) -----------------------
 *
 * Loads cd/TITLE.DAT + cd/TITLE.PAL into NBG2 during the title state.
 * The export_vdp2_image.py pipeline writes the bitmap rotated 90 deg CW,
 * so the on-disk 320x224 logical image becomes a 224-wide x 320-tall
 * stream that jo's NBG2 helper consumes verbatim.
 *
 * During STATE_TITLE we hide NBG1 (priority 0) so the underlying GHZ
 * playfield doesn't bleed through the title art; enter_game() restores
 * NBG1 priority to 6 and swaps NBG2 back to the GHZ sky.
 */
/* Title backdrop in NBG2 cell mode.
 *
 * jo_img_to_vdp2_cells does a horizontal-mirror + column-major pixel
 * pack per cell, then writes cells column-major. __jo_create_map then
 * reads them with y2 (image cell-row) wrapping at H/8 every 64 display-
 * column iterations. To display a 320x224 source upright the bitmap on
 * disk must be:
 *   - CW-rotated 90 deg (so jo's mirror+column-major cancels back to
 *     source orientation) -> 224 wide x 320 tall
 *   - padded to 512 tall (= 64 cells = CELL_COUNT_PER_ROW) so the y2
 *     wrap aligns with display row boundaries (matches GHZSKY's working
 *     176x512 layout).
 *   - padding bytes set to palette index 1 (NOT 0) so they read a real
 *     palette entry rather than jo's reserved CRAM[bank+0] which shows
 *     as magenta. */
#define TITLE_W  224
#define TITLE_H  512
static jo_palette g_title_pal;

static void setup_title_bg(void)
{
    static jo_img_8bits img;
    int len;
    unsigned short *tpal = (unsigned short *)jo_fs_read_file("TITLE.PAL", &len);
    jo_create_palette_from(&g_title_pal, tpal, 256);
    img.data   = (unsigned char *)jo_fs_read_file("TITLE.DAT", &len);
    img.width  = TITLE_W;
    img.height = TITLE_H;
    jo_vdp2_set_nbg2_8bits_image(&img, g_title_pal.id, false, true);
    /* Reset NBG2 scroll to (0,0) -- the GAME state's slScrPosNbg2(cam_x>>2,...)
     * leaves a non-zero scroll on the NBG2 plane, and that scroll persists if
     * we re-enter the title via state machine (or from any prior write). The
     * symptom was: light-blue (sky) bars showing on the left + right of the
     * title viewport because the visible 320 px were sampling columns far
     * past the bitmap's content extent. Pinning the scroll to (0,0) here
     * ensures the on-disk bitmap col 0 lines up with screen col 0. */
    slScrPosNbg2(0, 0);
}

