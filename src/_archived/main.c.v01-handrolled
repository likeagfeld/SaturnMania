    int len, i, w, h, fc;
    unsigned short *spr;
    const unsigned char *r;

    /* Sprite frames (cd/RING.SPR: u16 BE count + w + h + frames * w*h u16).
     * jo_sprite_add copies into VDP1 VRAM, so we can free the source after. */
    spr = (unsigned short *)jo_fs_read_file("RING.SPR", &len);
    fc = spr[0]; w = spr[1]; h = spr[2];
    if (fc > RING_FRAMES) fc = RING_FRAMES;
    {
        jo_img img;
        for (i = 0; i < fc; ++i) {
            img.data   = (jo_color *)(spr + 3) + i * w * h;
            img.width  = w;
            img.height = h;
            g_sprite_ring[i] = jo_sprite_add(&img);
        }
    }
    jo_free(spr);

    /* World positions (cd/GHZRINGS.BIN: u16 BE count + per-ring u16 BE x,y).
     * SH-2 is big-endian so the u16 pair reads natively as a struct of two
     * shorts; we keep the raw pointer and decode at access time. */
    r = (const unsigned char *)zone_alloc_track(ZA_RINGS,
            jo_fs_read_file(zone_path("RINGS.BIN"), &len));
    g_ring_count = *(const unsigned short *)r;
    if (g_ring_count > RING_MAX) g_ring_count = RING_MAX;
    g_rings_buf = r + 2;

    for (i = 0; i < g_ring_count; ++i) g_ring_active[i] = 1;
    g_rings_collected = 0;
}

/* Cull, hit-test against Sonic, and draw active rings. Called from draw_game
 * once per frame. Camera-space culling skips off-screen rings cheaply so the
 * full 446-ring sweep stays under budget on 28.6 MHz SH-2. */
static void draw_rings(int cam_x, int cam_y, int sonic_px, int sonic_py)
{
    int i;
    int frame = (g_ticks >> 2) % RING_FRAMES;       /* spin every 4 ticks   */

    for (i = 0; i < g_ring_count; ++i) {
        int rx, ry, sx, sy, dx, dy;
        if (!g_ring_active[i]) continue;
        rx = *(const unsigned short *)(g_rings_buf + (i << 2));
        ry = *(const unsigned short *)(g_rings_buf + (i << 2) + 2);
        sx = rx - cam_x;
        sy = ry - cam_y;
        if (sx < -RING_W || sx > SCR_W + RING_W ||
            sy < -RING_H || sy > SCR_H + RING_H) continue;

        /* AABB hit-test vs Sonic. His body roughly 32x40 centered at
         * (xpos, ypos-SPR_H/2). Ring centre is at (rx+8, ry+8). */
        dx = sonic_px - (rx + RING_W / 2);
        dy = (sonic_py - SPR_H / 2) - (ry + RING_H / 2);
        if (dx > -22 && dx < 22 && dy > -28 && dy < 28) {
            g_ring_active[i] = 0;
            ++g_rings_collected;
            g_score += 10;                          /* classic Sonic: 10 per ring */
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
            if (g_audio_ready) jo_audio_play_sound(&g_sfx_ring);
#endif
            continue;
        }

        /* jo_sprite_draw3D is centre-origin -- ring centre on screen at
         * (sx+8, sy+8); convert via -160, -112. */
        jo_sprite_draw3D(g_sprite_ring[frame],
                         (sx + RING_W / 2) - 160,
                         (sy + RING_H / 2) - 112,
                         SPRITE_Z);
    }
}

/* ---- Badniks (cd/GHZBUGS.BIN positions, cd/BADNIK.SPR sprite) ---------
 * Per-bug state machine: walks along the surface table at a fixed speed,
 * flips facing on cliffs and walls (same thresholds the player physics
 * uses), tested against Sonic's hitbox each frame. Stomp-from-above kills
 * the bug + bounces Sonic + awards 100 score; contact-from-the-side hurts
 * Sonic. The proper hurt-state machine (invuln flash, ring-scatter
 * physics, knockback) lands in Phase 5; for this iteration "hurt" just
 * zeros the ring counter so the effect is visible without the full state.
 *
 * Sprite is a procedural 4-frame placeholder I draw myself in
 * tools/make_badnik_sprite.py. Drop a hand-extracted MOTOBUG.SPR with the
 * same layout at cd/BADNIK.SPR and the engine picks it up. */
#define BUG_MAX        32
#define BUG_FRAMES     4
#define BUG_W          16
#define BUG_H          16
#define BUG_SPEED      SMS_FIXED(0.5)     /* px/frame patrol speed         */
#define BUG_WALL_PX    14                  /* same stair-step tolerance      */
#define BUG_CLIFF_PX   18

typedef struct {
    jo_fixed     x;          /* world position, Q16.16 */
    int          y;          /* world Y in pixels (snapped to surface)       */
    signed char  vx_dir;     /* -1 = left, +1 = right                        */
    unsigned char active;
} sms_bug_t;

static sms_bug_t  g_bug[BUG_MAX];
static int        g_bug_count;
static int        g_bug_spr[BUG_FRAMES];

static void load_badniks(void)
{
    int                       len, i, w, h, fc;
    unsigned short           *spr;
    const unsigned char      *r;
    unsigned short            count;
    jo_img                    img;

    /* Sprite frames. */
    spr = (unsigned short *)jo_fs_read_file("BADNIK.SPR", &len);
    fc = spr[0]; w = spr[1]; h = spr[2];
    if (fc > BUG_FRAMES) fc = BUG_FRAMES;
    for (i = 0; i < fc; ++i) {
        img.data   = (jo_color *)(spr + 3) + i * w * h;
        img.width  = w;
        img.height = h;
        g_bug_spr[i] = jo_sprite_add(&img);
    }
    jo_free(spr);                                   /* VDP1 has the pixels now */

    /* World positions (cd/GHZBUGS.BIN, u16 BE count + per-bug u16 BE x,y). */
    r = (const unsigned char *)zone_alloc_track(ZA_BUGS,
            jo_fs_read_file(zone_path("BUGS.BIN"), &len));
    count = *(const unsigned short *)r;
    if (count > BUG_MAX) count = BUG_MAX;
    g_bug_count = count;
    for (i = 0; i < g_bug_count; ++i) {
        unsigned short bx = *(const unsigned short *)(r + 2 + (i << 2));
        unsigned short by = *(const unsigned short *)(r + 2 + (i << 2) + 2);
        g_bug[i].x      = JO_MULT_BY_65536((int)bx);
        g_bug[i].y      = (int)by;
        g_bug[i].vx_dir = -1;               /* start walking left, classic */
        g_bug[i].active = 1;
    }
}

/* Update + render every active badnik. Called from draw_game each frame. */
static void draw_badniks(int cam_x, int cam_y, int sonic_px, int sonic_py)
{
    int  frame = (g_ticks >> 3) % BUG_FRAMES;       /* walk cycle, ~8 ticks per */
    int  i;

    for (i = 0; i < g_bug_count; ++i) {
        sms_bug_t *b = &g_bug[i];
        int        bx_int, dx, dy, ahead_y;
        jo_fixed   new_x;
        int        sx, sscreen;

        if (!b->active) continue;

        /* --- patrol step ------------------------------------------------ */
        new_x  = b->x + (b->vx_dir > 0 ? BUG_SPEED : -BUG_SPEED);
        bx_int = JO_FIXED_TO_INT(new_x);
        if (bx_int < 0)                       bx_int = 0;
        if (bx_int >= g_world.width_px)       bx_int = g_world.width_px - 1;

        ahead_y = player_surface_y(&g_world, bx_int);
        if (ahead_y == SMS_NO_FLOOR ||
            ahead_y < b->y - BUG_WALL_PX ||             /* wall: flip */
            ahead_y > b->y + BUG_CLIFF_PX) {            /* cliff: flip */
            b->vx_dir = -b->vx_dir;
        } else {
            b->x = new_x;
            b->y = ahead_y;                              /* ground-follow */
        }

        /* --- cull + render ---------------------------------------------- */
        bx_int  = JO_FIXED_TO_INT(b->x);
        sx      = bx_int - cam_x;
        sscreen = b->y    - cam_y;
        if (sx < -BUG_W || sx > SCR_W + BUG_W ||
            sscreen < -BUG_H || sscreen > SCR_H + BUG_H) continue;

        /* --- hit-test vs Sonic ----------------------------------------- *
         * Sonic's body bbox: 32x40 centred at (xpos, ypos-SPR_H/2).
         * Bug's bbox: BUG_WxBUG_H with the bug's feet on the surface, so
         * its centre is (bx_int, b->y - BUG_H/2). Stomp condition: Sonic's
         * feet are at-or-above the bug's centre AND Sonic is falling. */
        dx = sonic_px - bx_int;
        dy = (sonic_py - SPR_H / 2) - (b->y - BUG_H / 2);
        if (dx > -24 && dx < 24 && dy > -32 && dy < 24) {
            int sonic_feet  = sonic_py;
            int bug_centre  = b->y - BUG_H / 2;
            if (sonic_feet <= bug_centre + 4 &&
                g_player.ysp >= 0 && !g_player.grounded) {
                /* STOMP */
                b->active     = 0;
                g_score      += 100;
                g_player.ysp  = -SMS_FIXED(4.0);        /* bounce */
                g_player.jumping = true;
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                if (g_audio_ready) jo_audio_play_sound(&g_sfx_stomp);
#endif
            } else {
                /* Phase 4 hurt path. Invuln/dead checks gate so we don't
                 * stack damage during the flash window. */
                if (g_hurt_timer > 0 || g_dead) {
                    continue;
                }
                if (g_rings_collected > 0) {
                    /* Took damage with rings: scatter rings (zero them for
                     * the MVP -- ring-burst arcs land in Phase 4.1), apply
                     * knockback, start the 120-tick invuln flash. */
                    g_rings_collected = 0;
                    g_hurt_timer      = 120;
                    g_player.ysp      = -SMS_FIXED(4.0);
                    g_player.xsp      = g_player.facing_left
                                          ? SMS_FIXED(2.0)
                                          : -SMS_FIXED(2.0);
                    g_player.grounded = false;
                    g_player.jumping  = true;
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                    if (g_audio_ready) jo_audio_play_sound(&g_sfx_lose);
#endif
                } else {
                    /* Took damage with 0 rings: death. The state-machine
                     * handler in STATE_GAME triggers respawn / game-over. */
                    g_dead = true;
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                    if (g_audio_ready) jo_audio_play_sound(&g_sfx_hurt);
#endif
                }
            }
            continue;
        }

        /* Flip the sprite when walking left so the eyes face the direction. */
        if (b->vx_dir < 0) jo_sprite_enable_horizontal_flip();
        jo_sprite_draw3D(g_bug_spr[frame],
                         (sx + BUG_W / 2) - 160,
                         (sscreen - BUG_H / 2) - 112,
                         SPRITE_Z);
        if (b->vx_dir < 0) jo_sprite_disable_horizontal_flip();
    }
}

/* ---- Static interactive objects: Spring, Monitor, SignPost ------------
 * Same data shape as Ring / Motobug: u16 count + per-entity u16 BE worldX +
 * worldY in cd/GHZSPRG.BIN, cd/GHZBOX.BIN, cd/GHZSIGN.BIN. Each gets a
 * small active-flag array so picked-up / broken objects stay gone for the
 * rest of the act. Sprites at cd/SPRING.SPR / cd/MONITOR.SPR / cd/SIGNPOST.SPR. */

#define OBJ_MAX           64
#define SPRING_FORCE      SMS_FIXED(10.0)  /* yellow Mania spring up-launch    */
#define MONITOR_RINGS     10                /* placeholder: each box = +10 rings */

static const unsigned char *g_spring_buf;
static unsigned short       g_spring_count;
static unsigned char        g_spring_active[OBJ_MAX];
static unsigned char        g_spring_anim[OBJ_MAX];  /* 0=neutral, 1..N animating */
static int                  g_sprite_spring[3];      /* extended / neutral / compr */

static const unsigned char *g_monitor_buf;
static unsigned short       g_monitor_count;
static unsigned char        g_monitor_active[OBJ_MAX];
static int                  g_sprite_monitor;

#define SIGN_FRAMES   8                /* "Sonic" anim in SignPost.bin = 8 frames */
static const unsigned char *g_sign_buf;
static unsigned short       g_sign_count;
static int                  g_sprite_sign[SIGN_FRAMES];
static bool                 g_act_cleared;

/* Phase 3 act-clear / tally state. g_state_tick counts ticks-in-current-state
 * (zeroed each time we transition); ACTCLEAR spins the signpost, TALLY rolls
 * up the bonus digits. g_tally_total is the running counter that grows from 0
 * to (time_bonus + ring_bonus) as the digits roll. */
static int g_state_tick;
static int g_tally_time_bonus;
static int g_tally_ring_bonus;
static int g_tally_total;
static int g_tally_act_x;             /* Sonic's screen-X during walk-off */

static void load_objects(void)
{
    int                  len, i, w, h, fc;
    unsigned short      *spr;
    const unsigned char *r;
    jo_img               img;

    /* --- Springs -------------------------------------------------------- */
    spr = (unsigned short *)jo_fs_read_file("SPRING.SPR", &len);
    fc = spr[0]; w = spr[1]; h = spr[2];
    if (fc > 3) fc = 3;
    for (i = 0; i < fc; ++i) {
        img.data = (jo_color *)(spr + 3) + i * w * h;
        img.width = w; img.height = h;
        g_sprite_spring[i] = jo_sprite_add(&img);
    }
    jo_free(spr);
    r = (const unsigned char *)zone_alloc_track(ZA_SPRINGS,
            jo_fs_read_file(zone_path("SPRG.BIN"), &len));
    g_spring_count = *(const unsigned short *)r;
    if (g_spring_count > OBJ_MAX) g_spring_count = OBJ_MAX;
    g_spring_buf = r + 2;
    for (i = 0; i < g_spring_count; ++i) {
        g_spring_active[i] = 1;
        g_spring_anim[i]   = 0;
    }

    /* --- Monitors ------------------------------------------------------- */
    spr = (unsigned short *)jo_fs_read_file("MONITOR.SPR", &len);
    w = spr[1]; h = spr[2];
    img.data = (jo_color *)(spr + 3);
    img.width = w; img.height = h;
    g_sprite_monitor = jo_sprite_add(&img);
    jo_free(spr);

    r = (const unsigned char *)zone_alloc_track(ZA_MONITORS,
            jo_fs_read_file(zone_path("BOX.BIN"), &len));
    g_monitor_count = *(const unsigned short *)r;
    if (g_monitor_count > OBJ_MAX) g_monitor_count = OBJ_MAX;
    g_monitor_buf = r + 2;
    for (i = 0; i < g_monitor_count; ++i) g_monitor_active[i] = 1;

    /* --- Signposts ------------------------------------------------------
     * SIGNPOST.SPR holds 8 frames of the spinning post ("Sonic" anim from
     * Data/Sprites/Global/SignPost.bin via tools/convert_anim_sprite.py).
     * In STATE_GAME we draw frame 0 (idle/upright); in STATE_ACTCLEAR we
     * cycle through 0..7 to animate the spin. */
    spr = (unsigned short *)jo_fs_read_file("SIGNPOST.SPR", &len);
    fc = spr[0]; w = spr[1]; h = spr[2];
    if (fc > SIGN_FRAMES) fc = SIGN_FRAMES;
    for (i = 0; i < fc; ++i) {
        img.data = (jo_color *)(spr + 3) + i * w * h;
        img.width = w; img.height = h;
        g_sprite_sign[i] = jo_sprite_add(&img);
    }
    jo_free(spr);

    r = (const unsigned char *)zone_alloc_track(ZA_SIGNS,
            jo_fs_read_file(zone_path("SIGN.BIN"), &len));
    g_sign_count = *(const unsigned short *)r;
    g_sign_buf = r + 2;
    g_act_cleared = false;
}

/* Springs -- AABB hit from above launches Sonic up, plays jump SFX, and
 * animates the spring (compressed -> extended -> neutral over a few ticks). */
static void draw_springs(int cam_x, int cam_y, int sonic_px, int sonic_py)
{
    int i;
    for (i = 0; i < g_spring_count; ++i) {
        int rx, ry, sx, sy, dx, dy, frame;
        rx = *(const unsigned short *)(g_spring_buf + (i << 2));
        ry = *(const unsigned short *)(g_spring_buf + (i << 2) + 2);
        sx = rx - cam_x; sy = ry - cam_y;
        if (sx < -16 || sx > SCR_W + 16 || sy < -16 || sy > SCR_H + 16) continue;

        if (g_spring_active[i]) {
            /* hit-test: Sonic's feet are within 6 px above the spring top and
             * not moving upward => launch. */
            dx = sonic_px - rx;
            dy = sonic_py - (ry - 4);                /* spring top */
            if (dx > -10 && dx < 10 && dy > -6 && dy < 8 &&
                g_player.ysp >= 0) {
                g_player.ysp     = -SPRING_FORCE;
                g_player.grounded = false;
                g_player.jumping  = true;
                g_spring_anim[i]  = 12;              /* 12 ticks of squash anim */
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                if (g_audio_ready) jo_audio_play_sound(&g_sfx_bounce);
#endif
            }
        }

        /* frame: 0..3 = compressed, 4..7 = extended, 8..11 = compressed again,
         * else neutral. Sequence: SQUASH -> POP -> settle. */
        if (g_spring_anim[i]) {
            int a = g_spring_anim[i]--;
            frame = (a > 8) ? 2 : (a > 4) ? 0 : 2;     /* compr, ext, compr */
        } else {
            frame = 1;                                 /* neutral */
        }
        jo_sprite_draw3D(g_sprite_spring[frame],
                         (sx + 8) - 160, (sy + 8) - 112, SPRITE_Z);
    }
}

/* Monitors -- AABB hit while not-fully-on-ground (jumping or rolling) breaks
 * the box and grants +10 rings (placeholder; full powerup table is Phase 5). */
static void draw_monitors(int cam_x, int cam_y, int sonic_px, int sonic_py)
{
    int i;
    /* Monitor sprite is 16x16 with centre at (rx+8, ry+8) per the
     * jo_sprite_draw3D call below. The world Y stored in GHZ1BOX.BIN
     * (and analogues per zone) is the AUTHORED position. Snap the
     * BOTTOM EDGE of each monitor to the surface at its column so it
     * sits flush on grass / mound tops, never overlapping the dirt
     * geometry or floating. User reported 2026-05-26: "tv screen
     * sprites are not sitting on grass and sitting overlapped on
     * mound ground". */
    const int MONITOR_H = 16;
    for (i = 0; i < g_monitor_count; ++i) {
        int rx, ry, sx, sy, dx, dy, snap_y;
        if (!g_monitor_active[i]) continue;
        rx = *(const unsigned short *)(g_monitor_buf + (i << 2));
        ry = *(const unsigned short *)(g_monitor_buf + (i << 2) + 2);
        /* Ground-snap: align sprite bottom (ry + MONITOR_H) to the
         * surface at the monitor's column. If the surface has no
         * floor (pit / unreachable column), fall back to authored Y. */
        snap_y = player_surface_y(&g_world, rx + (MONITOR_H / 2));
        if (snap_y != SMS_NO_FLOOR) ry = snap_y - MONITOR_H;
        sx = rx - cam_x; sy = ry - cam_y;
        if (sx < -16 || sx > SCR_W + 16 || sy < -16 || sy > SCR_H + 16) continue;

        /* monitor centre vs Sonic body centre */
        dx = sonic_px - rx;
        dy = (sonic_py - SPR_H / 2) - ry;
        if (dx > -20 && dx < 20 && dy > -24 && dy < 20 &&
            (!g_player.grounded || g_player.rolling)) {
            g_monitor_active[i] = 0;
            g_rings_collected  += MONITOR_RINGS;
            g_score            += 100;
            g_player.ysp        = -SMS_FIXED(3.0);    /* small bounce */
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
            if (g_audio_ready) jo_audio_play_sound(&g_sfx_break);
#endif
            continue;
        }
        jo_sprite_draw3D(g_sprite_monitor,
                         (sx + 8) - 160, (sy + 8) - 112, SPRITE_Z);
    }
}

/* Signpost -- touch ends the act. Full bonus tally + transition is Phase 5;
 * for this iteration we just set g_act_cleared which freezes autorun and
 * lets the timer keep showing the clear time. */
static void draw_signpost(int cam_x, int cam_y, int sonic_px, int sonic_py)
{
    int i;
    for (i = 0; i < g_sign_count; ++i) {
        int rx, ry, sx, sy, dx, dy;
        rx = *(const unsigned short *)(g_sign_buf + (i << 2));
        ry = *(const unsigned short *)(g_sign_buf + (i << 2) + 2);
        sx = rx - cam_x; sy = ry - cam_y;
        if (sx < -16 || sx > SCR_W + 16 || sy < -24 || sy > SCR_H + 24) continue;

        if (!g_act_cleared) {
            dx = sonic_px - rx;
            dy = sonic_py - ry;
            if (dx > -24 && dx < 24 && dy > -32 && dy < 12) {
                /* Phase 3: signpost touch enters STATE_ACTCLEAR, which spins
                 * the signpost over ~120 ticks while Sonic walks off-screen,
                 * then enters STATE_TALLY for the bonus roll-up. The
                 * STATE_TALLY exit calls zone_advance() (preserving score). */
                g_act_cleared    = true;
                g_autorun        = false;  /* freeze player input during cinematic */
                g_score         += 1000;   /* signpost-touch bonus */
                g_tally_act_x    = JO_FIXED_TO_INT(g_player.xpos);
#ifdef JO_COMPILE_WITH_AUDIO_SUPPORT
                if (g_audio_ready) jo_audio_play_sound(&g_sfx_ring);
#endif
                enter_actclear();   /* snapshots time/ring bonuses */
                return;             /* draw_actclear handles sprite from here */
            }
        }
        /* Normal gameplay draws frame 0 (upright signpost). In STATE_ACTCLEAR
         * / STATE_TALLY the spinning frame is drawn by draw_actclear instead,
         * so skip the upright here to avoid double-rendering. */
        if (!g_act_cleared) {
            jo_sprite_draw3D(g_sprite_sign[0],
                             (sx + 8) - 160, (sy + 12) - 112, SPRITE_Z);
        }
    }
}

/* ---- HUD glyphs (cd/DIGITS.SPR: 12 frames of 8x8 BGR1555) ------------- */
#define HUD_GLYPHS    12        /* 0..9 + ring-icon + colon                  */
#define DIGIT_W       8
#define DIGIT_H       8
#define GLYPH_RING    10        /* gold ring icon                            */
#define GLYPH_COLON   11        /* two stacked dots, for the timer separator */
#define HUD_Z         100
#define HUD_X         8
#define HUD_Y         8         /* line 0 = rings, line 1 = score, line 2 = timer */
#define HUD_LINE_H    10

/* (HUD storage moved up next to the ring globals so draw_rings() can bump
 * g_score from the pickup branch -- see the block above load_rings.) */

static void load_hud_digits(void)
{
    int len, i, w, h, fc;
    unsigned short *spr;

    spr = (unsigned short *)jo_fs_read_file("DIGITS.SPR", &len);
    fc = spr[0]; w = spr[1]; h = spr[2];
    if (fc > HUD_GLYPHS) fc = HUD_GLYPHS;
    {
        jo_img img;
        for (i = 0; i < fc; ++i) {
